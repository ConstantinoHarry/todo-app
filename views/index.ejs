<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="app-shell">
      <div class="app-container">
        <%- include('partials/header') %>

        <%
          var overallCompletionRate = counts.total > 0
            ? Math.round((counts.completed / counts.total) * 100)
            : 0;
          var progressCompletionRate = progressSummary && typeof progressSummary.rate === 'number'
            ? progressSummary.rate
            : 0;
          var progressFilterLabel = selectedProgressFilter === 'today'
            ? 'Due today'
            : selectedProgressFilter === 'week'
              ? 'Due this week'
              : 'All tasks';
          var buildViewPath = function(viewValue, monthValue, dateValue) {
            var params = [];
            if (viewValue && viewValue !== 'required') {
              params.push('view=' + encodeURIComponent(viewValue));
            }
            if (selectedEnergyFilter && selectedEnergyFilter !== 'all') {
              params.push('energy=' + encodeURIComponent(selectedEnergyFilter));
            }
            if (selectedDueFilter && selectedDueFilter !== 'all') {
              params.push('due=' + encodeURIComponent(selectedDueFilter));
            }
            if (selectedProgressFilter && selectedProgressFilter !== 'all') {
              params.push('progress=' + encodeURIComponent(selectedProgressFilter));
            }
            if (monthValue) {
              params.push('month=' + encodeURIComponent(monthValue));
            }
            if (dateValue) {
              params.push('date=' + encodeURIComponent(dateValue));
            }
            return params.length ? '/?' + params.join('&') : '/';
          };
          var toDatetimeLocal = function(d) {
            if (!d) return '';
            var dt = new Date(d);
            var pad = function(n) { return String(n).padStart(2, '0'); };
            return dt.getFullYear() + '-' + pad(dt.getMonth() + 1) + '-' + pad(dt.getDate()) + 'T' + pad(dt.getHours()) + ':' + pad(dt.getMinutes());
          };
          var fmtDeadline = function(d) {
            var dt = new Date(d);
            return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + ' · ' + dt.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
          };
          var buildListPath = function(viewValue) {
            return buildViewPath(viewValue, selectedCalendarMonth, selectedCalendarDate);
          };
        %>

        <% if (error) { %>
          <section class="alert alert-error" aria-live="polite">
            <p><%= error %></p>
          </section>
        <% } %>

        <% if (success) { %>
          <section class="alert alert-success" aria-live="polite">
            <p><%= success %></p>
          </section>
        <% } %>

        <section class="hero-metrics">
          <div class="hero-metrics-copy">
            <h2>Your productivity dashboard</h2>
            <p>
              Plan by energy, reduce overwhelm, and keep your daily work visually organized.
            </p>
          </div>

          <div class="hero-metrics-actions">
            <button
              type="button"
              class="btn btn-ghost focus-mode-btn"
              data-focus-mode-toggle
              aria-pressed="false"
              aria-label="Toggle Focus Mode"
            >
              <span class="focus-mode-btn-icon" aria-hidden="true">🌙</span>
              <span data-focus-mode-label>Focus Mode</span>
            </button>
          </div>
        </section>

        <section class="stats-grid" aria-label="Task overview">
          <article class="stat-card stat-card-total">
            <span class="stat-label">Total Tasks</span>
            <strong class="stat-value"><%= counts.total %></strong>
          </article>
          <article class="stat-card stat-card-open">
            <span class="stat-label">Open</span>
            <strong class="stat-value"><%= counts.open %></strong>
          </article>
          <article class="stat-card stat-card-completed">
            <span class="stat-label">Completed</span>
            <strong class="stat-value"><%= counts.completed %></strong>
          </article>
          <article class="stat-card stat-card-progress">
            <span class="stat-label">Progress</span>
            <strong class="stat-value"><%= overallCompletionRate %>%</strong>
          </article>
        </section>

        <section class="dashboard-grid">
          <div class="dashboard-main">
            <section class="progress-card section-card" aria-label="Progress tracker">
              <div class="progress-card-top">
                <div class="progress-card-copy">
                  <p class="section-kicker">Overview</p>
                  <h2>Today’s Progress</h2>
                  <p>Track how much of your current list is already done.</p>
                </div>
                <div class="progress-card-score" aria-label="Completion summary">
                  <span class="progress-score-label">Completion</span>
                  <strong class="progress-score-value"><%= progressCompletionRate %>%</strong>
                  <span class="progress-badge"><%= progressFilterLabel %></span>
                </div>
              </div>

              <div class="progress-card-controls">
                <form action="/" method="GET" class="task-filter-form progress-filter-form">
                  <input type="hidden" name="view" value="<%= selectedView %>" />
                  <input type="hidden" name="energy" value="<%= selectedEnergyFilter %>" />
                  <input type="hidden" name="due" value="<%= selectedDueFilter %>" />
                  <label class="sr-only" for="progressFilter">Progress range</label>
                  <select id="progressFilter" name="progress">
                    <option value="all" <%= selectedProgressFilter === 'all' ? 'selected' : '' %>>All tasks</option>
                    <option value="today" <%= selectedProgressFilter === 'today' ? 'selected' : '' %>>Due today</option>
                    <option value="week" <%= selectedProgressFilter === 'week' ? 'selected' : '' %>>Due this week</option>
                  </select>
                  <button type="submit" class="btn btn-ghost task-filter-btn progress-apply-btn">Apply</button>
                </form>

              </div>

              <div class="progress-wrap">
                <progress
                  class="progress-native"
                  value="<%= progressCompletionRate %>"
                  max="100"
                  aria-label="Completion progress"
                ></progress>
              </div>
            </section>

            <section class="todo-list-section section-card" aria-label="Task list">
              <div class="task-toolbar">
                <div class="task-toolbar-primary">
                  <button type="button" class="btn btn-primary" data-open-add-task-modal>
                    + New Task
                  </button>

                  <div class="task-view-toggle" role="group" aria-label="Task view toggle">
                    <a href="<%= buildListPath('required') %>" class="btn btn-ghost task-view-btn <%= selectedView === 'required' ? 'is-active' : '' %>">Required</a>
                    <a href="<%= buildListPath('completed') %>" class="btn btn-ghost task-view-btn <%= selectedView === 'completed' ? 'is-active' : '' %>">Completed</a>
                    <a href="<%= buildViewPath('calendar', selectedCalendarMonth, selectedCalendarDate) %>" class="btn btn-ghost task-view-btn <%= selectedView === 'calendar' ? 'is-active' : '' %>">Calendar</a>
                  </div>
                </div>

                <form action="/" method="GET" class="task-filter-form">
                  <input type="hidden" name="view" value="<%= selectedView %>" />
                  <input type="hidden" name="progress" value="<%= selectedProgressFilter %>" />
                  <input type="hidden" name="month" value="<%= selectedCalendarMonth %>" />
                  <input type="hidden" name="date" value="<%= selectedCalendarDate %>" />
                  <label class="sr-only" for="listEnergyFilter">Energy filter</label>
                  <select id="listEnergyFilter" name="energy">
                    <option value="all" <%= selectedEnergyFilter === 'all' ? 'selected' : '' %>>All energy</option>
                    <option value="high" <%= selectedEnergyFilter === 'high' ? 'selected' : '' %>>⚡ High</option>
                    <option value="medium" <%= selectedEnergyFilter === 'medium' ? 'selected' : '' %>>😊 Medium</option>
                    <option value="low" <%= selectedEnergyFilter === 'low' ? 'selected' : '' %>>😴 Low</option>
                  </select>

                  <label class="sr-only" for="listDueFilter">Due date filter</label>
                  <select id="listDueFilter" name="due">
                    <option value="all" <%= selectedDueFilter === 'all' ? 'selected' : '' %>>All due dates</option>
                    <option value="today" <%= selectedDueFilter === 'today' ? 'selected' : '' %>>Due today</option>
                    <option value="overdue" <%= selectedDueFilter === 'overdue' ? 'selected' : '' %>>Overdue</option>
                    <option value="upcoming" <%= selectedDueFilter === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                    <option value="none" <%= selectedDueFilter === 'none' ? 'selected' : '' %>>No due date</option>
                  </select>

                  <button type="submit" class="btn btn-ghost task-filter-btn">Apply</button>
                </form>
              </div>

              <div class="section-heading">
                <div>
                  <p class="section-kicker">Tasks</p>
                  <h2><%= selectedView === 'completed' ? 'Completed Tasks' : selectedView === 'calendar' ? 'Task Calendar' : 'Required Tasks' %></h2>
                  <p class="todo-meta">
                    <% if (selectedView === 'calendar') { %>
                      Showing <strong><%= calendarView.scheduledTaskCount %></strong> scheduled task(s) in <strong><%= calendarView.monthLabel %></strong>
                    <% } else { %>
                      Showing <strong><%= visibleTodos.length %></strong>
                      <%= selectedView === 'completed' ? 'completed' : 'required' %> task(s)
                    <% } %>
                  </p>
                </div>

                <% if (selectedView === 'completed') { %>
                  <form action="/todos/clear-completed" method="POST" class="inline-form" data-clear-completed-form>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                    <button type="submit" class="btn btn-danger">Clear Completed</button>
                  </form>
                <% } %>
              </div>

              <% if (selectedView === 'calendar') { %>
                <div class="calendar-toolbar">
                  <div class="calendar-nav" role="navigation" aria-label="Calendar month navigation">
                    <a href="<%= buildViewPath('calendar', calendarView.prevMonthKey) %>" class="btn btn-ghost calendar-nav-btn">&larr; Previous</a>
                    <div class="calendar-nav-copy">
                      <strong><%= calendarView.monthLabel %></strong>
                      <span><%= calendarView.scheduledTaskCount %> scheduled task(s)</span>
                    </div>
                    <a href="<%= buildViewPath('calendar', calendarView.nextMonthKey) %>" class="btn btn-ghost calendar-nav-btn">Next &rarr;</a>
                  </div>

                  <% if (calendarView.monthKey !== calendarView.todayMonthKey) { %>
                    <a href="<%= buildViewPath('calendar', calendarView.todayMonthKey, calendarView.todayDateKey) %>" class="btn btn-ghost calendar-today-btn">Jump to today</a>
                  <% } %>
                </div>

                <% if (!calendarView.scheduledTaskCount) { %>
                  <div class="empty-state-card calendar-empty-state">
                    <p class="empty-state-title">No scheduled tasks found for this month.</p>
                    <p class="empty-state">
                      Add deadlines to tasks or adjust your filters to populate the calendar.
                    </p>
                  </div>
                <% } %>

                <section class="calendar-view" aria-label="Monthly task calendar">
                  <div class="calendar-weekdays" aria-hidden="true">
                    <% calendarView.weekdayLabels.forEach(function(label) { %>
                      <span><%= label %></span>
                    <% }); %>
                  </div>

                  <div class="calendar-grid">
                    <% calendarView.weeks.forEach(function(week) { %>
                      <% week.forEach(function(day) { %>
                        <article class="calendar-day <%= day.inCurrentMonth ? '' : 'is-outside-month' %> <%= day.isToday ? 'is-today' : '' %> <%= day.isSelected ? 'is-selected' : '' %>">
                          <div class="calendar-day-header">
                            <a href="<%= buildViewPath('calendar', selectedCalendarMonth, day.dateKey) %>" class="calendar-day-link" aria-label="Open tasks for <%= day.dateKey %>">
                              <span class="calendar-day-number"><%= day.dayNumber %></span>
                            </a>
                            <% if (day.tasks.length) { %>
                              <span class="calendar-day-count"><%= day.tasks.length %></span>
                            <% } %>
                          </div>

                          <div class="calendar-day-tasks">
                            <% day.tasks.slice(0, 4).forEach(function(task) { %>
                              <a href="<%= buildViewPath('calendar', selectedCalendarMonth, day.dateKey) %>" class="calendar-task-chip <%= task.completed ? 'is-completed' : '' %> energy-<%= task.energy_level %>">
                                <span class="calendar-task-time"><%= task.timeLabel %></span>
                                <span class="calendar-task-text"><%= task.text %></span>
                              </a>
                            <% }); %>

                            <% if (day.tasks.length > 4) { %>
                              <a href="<%= buildViewPath('calendar', selectedCalendarMonth, day.dateKey) %>" class="calendar-more-tasks">+<%= day.tasks.length - 4 %> more</a>
                            <% } %>
                          </div>
                        </article>
                      <% }); %>
                    <% }); %>
                  </div>
                </section>

                <% if (calendarAgenda) { %>
                  <section class="calendar-agenda" aria-label="Selected date task details">
                    <div class="calendar-agenda-header">
                      <div>
                        <p class="section-kicker">Agenda</p>
                        <h3><%= calendarAgenda.label %></h3>
                        <p class="todo-meta">Showing <strong><%= calendarAgenda.tasks.length %></strong> task(s) for this date.</p>
                      </div>
                      <a href="<%= buildViewPath('calendar', selectedCalendarMonth) %>" class="btn btn-ghost calendar-agenda-clear-btn">Clear selection</a>
                    </div>

                    <% if (!calendarAgenda.tasks.length) { %>
                      <div class="empty-state-card calendar-empty-state">
                        <p class="empty-state-title">No tasks scheduled for this day.</p>
                        <p class="empty-state">Pick another date or add a deadline to a task.</p>
                      </div>
                    <% } else { %>
                      <ul class="calendar-agenda-list">
                        <% calendarAgenda.tasks.forEach(function(todo) { %>
                          <li class="calendar-agenda-item <%= todo.completed ? 'is-completed' : '' %>">
                            <div class="calendar-agenda-main">
                              <div class="calendar-agenda-topline">
                                <h4 class="calendar-agenda-title"><%= todo.text %></h4>
                                <span class="badge badge-<%= todo.energy_level %>">
                                  <%= todo.energy_level === 'high' ? '⚡ High Energy' : todo.energy_level === 'medium' ? '😊 Medium Energy' : '😴 Low Energy' %>
                                </span>
                              </div>

                              <% if (todo.description) { %>
                                <p class="calendar-agenda-description"><%= todo.description %></p>
                              <% } %>

                              <div class="calendar-agenda-meta-row">
                                <% if (todo.deadline) { %>
                                  <span class="deadline-badge <%= !todo.completed && new Date(todo.deadline) < new Date() ? 'is-overdue' : '' %>">
                                    <%= !todo.completed && new Date(todo.deadline) < new Date() ? '⚠ Overdue' : '📅 Due' %> · <%= fmtDeadline(todo.deadline) %>
                                  </span>
                                <% } %>

                                <% if ((todo.subtasks || []).length > 0) { %>
                                  <span class="subtask-count"><%= (todo.subtasks || []).filter(function(s){ return s.completed; }).length %>/<%= (todo.subtasks || []).length %> subtasks done</span>
                                <% } %>
                              </div>
                            </div>

                            <div class="calendar-agenda-actions">
                              <form action="/todos/<%= todo.id %>/toggle?_method=PATCH" method="POST" class="inline-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                                <button type="submit" class="btn btn-ghost"><%= todo.completed ? 'Reopen' : 'Mark done' %></button>
                              </form>

                              <form action="/todos/<%= todo.id %>?_method=DELETE" method="POST" class="inline-form">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                                <button type="submit" class="btn btn-ghost">Delete</button>
                              </form>
                            </div>
                          </li>
                        <% }); %>
                      </ul>
                    <% } %>
                  </section>
                <% } else { %>
                  <section class="calendar-agenda calendar-agenda-placeholder" aria-label="Select a date to inspect tasks">
                    <p class="empty-state-title">Select a date to inspect your schedule.</p>
                    <p class="empty-state">Click any day or task chip in the calendar to open its task details here.</p>
                  </section>
                <% } %>
              <% } else if (!visibleTodos.length) { %>
                <div class="empty-state-card">
                  <p class="empty-state-title"><%= selectedView === 'completed' ? 'No completed tasks found.' : 'No required tasks found.' %></p>
                  <p class="empty-state">
                    Try changing the filters or add a new task.
                  </p>
                </div>
              <% } else { %>
                <ul class="todo-list">
                  <% visibleTodos.forEach(function(todo) { %>
                    <li class="todo-item <%= selectedView === 'completed' ? 'completed' : '' %>">
                      <div class="todo-main">
                        <form action="/todos/<%= todo.id %>/toggle?_method=PATCH" method="POST" class="inline-form">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <label class="checkbox-row todo-checkbox-label" for="todo-<%= selectedView %>-<%= todo.id %>">
                            <input
                              id="todo-<%= selectedView %>-<%= todo.id %>"
                              type="checkbox"
                              name="completed"
                              onchange="this.form.submit()"
                              <%= todo.completed ? 'checked' : '' %>
                            />
                            <span class="todo-text"><%= todo.text %></span>
                          </label>
                        </form>

                        <% if (todo.description) { %>
                          <p class="todo-description"><%= todo.description %></p>
                        <% } %>

                        <% if (todo.deadline) { %>
                          <% var _isOverdue = !todo.completed && new Date(todo.deadline) < new Date(); %>
                          <p class="deadline-display">
                            <span class="deadline-badge <%= _isOverdue ? 'is-overdue' : '' %>">
                              <%= _isOverdue ? '⚠ Overdue' : '📅 Due' %> · <%= fmtDeadline(todo.deadline) %>
                            </span>
                          </p>
                        <% } %>

                        <% if (selectedView === 'required') { %>
                          <details class="edit-panel">
                            <summary>Edit task</summary>
                            <form action="/todos/<%= todo.id %>?_method=PATCH" method="POST" class="edit-form">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <input type="hidden" name="returnTo" value="<%= returnTo %>" />

                              <div class="form-field">
                                <label for="edit-text-<%= todo.id %>">Task text</label>
                                <input
                                  id="edit-text-<%= todo.id %>"
                                  type="text"
                                  name="text"
                                  value="<%= todo.text %>"
                                  maxlength="255"
                                  required
                                />
                              </div>

                              <div class="form-field">
                                <label for="edit-energy-<%= todo.id %>">Energy level</label>
                                <select id="edit-energy-<%= todo.id %>" name="energyLevel">
                                  <option value="high" <%= todo.energy_level === 'high' ? 'selected' : '' %>>⚡ High Energy</option>
                                  <option value="medium" <%= todo.energy_level === 'medium' ? 'selected' : '' %>>😊 Medium Energy</option>
                                  <option value="low" <%= todo.energy_level === 'low' ? 'selected' : '' %>>😴 Low Energy</option>
                                </select>
                              </div>

                              <div class="form-field">
                                <label for="edit-deadline-<%= todo.id %>">Deadline <span class="field-optional">(optional)</span></label>
                                <input
                                  id="edit-deadline-<%= todo.id %>"
                                  type="datetime-local"
                                  name="deadline"
                                  value="<%= toDatetimeLocal(todo.deadline) %>"
                                />
                              </div>

                              <button type="submit" class="btn btn-secondary">Save Changes</button>
                            </form>
                          </details>

                          <%
                            var _subTasks = todo.subtasks || [];
                            var _doneSubs = _subTasks.filter(function(s) { return s.completed; }).length;
                            var _totalSubs = _subTasks.length;
                            var _subPct = _totalSubs > 0 ? Math.round((_doneSubs / _totalSubs) * 100) : 0;
                          %>

                          <details class="subtask-section">
                            <summary class="subtask-summary">
                              <span class="subtask-summary-label">Subtasks</span>
                              <% if (_totalSubs > 0) { %>
                                <span class="subtask-count"><%= _doneSubs %>/<%= _totalSubs %> done</span>
                              <% } else { %>
                                <span class="subtask-count subtask-count-empty">none yet</span>
                              <% } %>
                            </summary>

                            <% if (_totalSubs > 0) { %>
                              <div class="subtask-progress-wrap">
                                <progress
                                  class="subtask-progress-bar"
                                  value="<%= _subPct %>"
                                  max="100"
                                  aria-label="Subtask completion progress"
                                ></progress>
                                <span class="subtask-progress-label"><%= _subPct %>% complete</span>
                              </div>
                            <% } %>

                            <% if (_subTasks.length > 0) { %>
                              <ul class="subtask-list">
                                <% _subTasks.forEach(function(subtask) { %>
                                  <li class="subtask-row">
                                    <form action="/todos/<%= todo.id %>/subtasks/<%= subtask.id %>/toggle?_method=PATCH" method="POST" class="inline-form subtask-toggle-form">
                                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                      <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                                      <label class="checkbox-row subtask-label" for="subtask-<%= subtask.id %>">
                                        <input
                                          id="subtask-<%= subtask.id %>"
                                          type="checkbox"
                                          onchange="this.form.submit()"
                                          <%= subtask.completed ? 'checked' : '' %>
                                        />
                                        <span class="subtask-text <%= subtask.completed ? 'is-done' : '' %>"><%= subtask.text %></span>
                                      </label>
                                    </form>
                                    <form action="/todos/<%= todo.id %>/subtasks/<%= subtask.id %>?_method=DELETE" method="POST" class="inline-form">
                                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                      <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                                      <button type="submit" class="subtask-delete-btn" aria-label="Delete subtask">&times;</button>
                                    </form>
                                  </li>
                                <% }); %>
                              </ul>
                            <% } %>

                            <form class="subtask-add-form" action="/todos/<%= todo.id %>/subtasks" method="POST">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                              <div class="subtask-input-row">
                                <input
                                  type="text"
                                  name="text"
                                  placeholder="Add a subtask…"
                                  maxlength="255"
                                  class="subtask-input"
                                />
                                <button type="submit" class="btn btn-ghost subtask-add-btn">Add</button>
                              </div>
                            </form>
                          </details>
                        <% } else if ((todo.subtasks || []).length > 0) { %>
                          <p class="subtask-summary-compact">
                            <span class="subtask-count"><%= (todo.subtasks || []).filter(function(s){ return s.completed; }).length %>/<%= (todo.subtasks || []).length %> subtasks done</span>
                          </p>
                        <% } %>
                      </div>

                      <div class="todo-actions">
                        <span class="badge badge-<%= todo.energy_level %>">
                          <%= todo.energy_level === 'high' ? '⚡ High Energy' : todo.energy_level === 'medium' ? '😊 Medium Energy' : '😴 Low Energy' %>
                        </span>

                        <form action="/todos/<%= todo.id %>?_method=DELETE" method="POST" class="inline-form">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
                          <button type="submit" class="btn btn-ghost">Delete</button>
                        </form>
                      </div>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </section>
          </div>
        </section>
      </div>

      <%- include('partials/footer') %>
    </main>

    <div class="task-modal-backdrop" data-add-task-modal hidden>
      <div class="task-modal" role="dialog" aria-modal="true" aria-labelledby="addTaskModalTitle">
        <div class="task-modal-header">
          <div>
            <p class="section-kicker">Create</p>
            <h3 id="addTaskModalTitle">Add a new task</h3>
          </div>
          <button type="button" class="task-modal-close" aria-label="Close" data-close-add-task-modal>&times;</button>
        </div>

        <form class="task-modal-form" action="/todos" method="POST" data-add-task-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="returnTo" value="<%= returnTo %>" />
          <input type="hidden" name="deadline" value="" data-deadline-hidden />
          <input type="hidden" name="subtasksJson" value="[]" data-subtasks-json />

          <div class="form-field">
            <label for="taskTextModal">Task name</label>
            <input
              id="taskTextModal"
              name="text"
              type="text"
              placeholder="What needs to be done?"
              required
              maxlength="255"
            />
          </div>

          <div class="form-field">
            <label for="taskDescriptionModal">Description <span class="field-optional">(optional)</span></label>
            <textarea
              id="taskDescriptionModal"
              name="description"
              rows="3"
              maxlength="1000"
              placeholder="Add context, notes, or acceptance criteria..."
            ></textarea>
          </div>

          <div class="task-modal-row task-modal-row-2">
            <div class="form-field">
              <label for="energyLevelModal">Energy level</label>
              <select id="energyLevelModal" name="energyLevel">
                <option value="high">⚡ High Energy</option>
                <option value="medium" selected>😊 Medium Energy</option>
                <option value="low">😴 Low Energy</option>
              </select>
            </div>

            <div class="form-field">
              <label for="taskDateModal">Due date <span class="field-optional">(optional)</span></label>
              <input id="taskDateModal" type="date" data-task-date />
            </div>
          </div>

          <div class="task-modal-row task-modal-row-2">
            <div class="form-field">
              <label for="taskTimeModal">Due time <span class="field-optional">(optional)</span></label>
              <input id="taskTimeModal" type="time" step="900" data-task-time />
            </div>
          </div>

          <div class="form-field task-subtasks-field">
            <div class="task-subtasks-header">
              <label>Subtasks <span class="field-optional">(optional)</span></label>
              <button type="button" class="btn btn-ghost" data-add-subtask-row>Add subtask</button>
            </div>

            <div class="task-subtask-list" data-subtask-list>
              <div class="task-subtask-row">
                <input
                  type="text"
                  maxlength="255"
                  placeholder="e.g. Draft outline"
                  data-subtask-input
                />
                <button type="button" class="subtask-delete-btn" aria-label="Remove subtask" data-remove-subtask>&times;</button>
              </div>
            </div>
          </div>

          <div class="task-modal-actions">
            <button type="button" class="btn btn-ghost" data-close-add-task-modal>Cancel</button>
            <button type="submit" class="btn btn-primary">Add Task</button>
          </div>
        </form>
      </div>
    </div>

    <script src="/js/main.js" defer></script>
  </body>
</html>