<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="auth-shell premium-auth-shell">
      <section class="auth-layout auth-layout-premium" aria-label="Forgot password page">
        <div class="auth-panel auth-panel-brand auth-panel-brand-premium">
          <div class="auth-brand-badge">Todo-App</div>

          <div class="auth-brand-copy auth-animate auth-animate-delay-1">
            <p class="auth-kicker">Recover account access</p>
            <h1>Reset your password securely</h1>
            <p class="auth-subtitle auth-subtitle-brand">
              Enter your account email and we’ll provide a reset link if an account exists.
            </p>
          </div>

          <div class="auth-brand-orb auth-brand-orb-one"></div>
          <div class="auth-brand-orb auth-brand-orb-two"></div>
          <div class="auth-grid-glow"></div>
        </div>

        <section class="auth-card auth-panel auth-card-premium auth-animate auth-animate-delay-2" aria-label="Forgot password form">
          <div class="auth-header">
            <p class="auth-kicker">Account recovery</p>
            <h2>Forgot password</h2>
            <p class="auth-subtitle">Submit your email to request a password reset link.</p>
          </div>

          <% if (error) { %>
            <section class="alert alert-error" aria-live="polite">
              <p><%= error %></p>
            </section>
          <% } %>

          <% if (success) { %>
            <section class="alert alert-success" aria-live="polite">
              <p><%= success %></p>
            </section>
          <% } %>

          <form class="auth-form" action="/forgot-password" method="POST" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <div class="form-field">
              <div class="floating-field">
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder=" "
                  required
                  autocomplete="email"
                />
                <label for="email">Email address</label>
              </div>
            </div>

            <button type="submit" class="btn btn-primary auth-submit btn-block">Send reset link</button>
          </form>

          <div class="auth-help auth-help-premium">
            <p>Remembered your password?</p>
            <a class="auth-back" href="/login">Back to login</a>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
