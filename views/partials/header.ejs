<header class="page-header">
  <div class="header-copy">
    <p class="eyebrow">Energy-aware productivity</p>
    <h1>Todo-App</h1>
    <p class="subtitle">
      Organize tasks by energy so you can still make meaningful progress on low-focus days.
    </p>
  </div>

  <div class="header-actions">
    <% if (isAuthenticated) { %>
      <span class="header-user"><%= currentUser && currentUser.email ? currentUser.email : 'Logged in' %></span>
      <form action="/logout" method="POST" class="inline-form">
        <button type="submit" class="btn btn-ghost btn-logout">Logout</button>
      </form>
    <% } else { %>
      <a href="/login" class="btn btn-ghost btn-logout">Login</a>
    <% } %>
  </div>

  <div class="header-orb header-orb-one"></div>
  <div class="header-orb header-orb-two"></div>
</header>