<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <main class="auth-shell premium-auth-shell">
      <section class="auth-layout auth-layout-premium" aria-label="Reset password page">
        <div class="auth-panel auth-panel-brand auth-panel-brand-premium">
          <div class="auth-brand-badge">Todo-App</div>

          <div class="auth-brand-copy auth-animate auth-animate-delay-1">
            <p class="auth-kicker">Secure reset</p>
            <h1>Create a new password</h1>
            <p class="auth-subtitle auth-subtitle-brand">
              Choose a strong password with at least 8 characters to secure your account.
            </p>
          </div>

          <div class="auth-brand-orb auth-brand-orb-one"></div>
          <div class="auth-brand-orb auth-brand-orb-two"></div>
          <div class="auth-grid-glow"></div>
        </div>

        <section class="auth-card auth-panel auth-card-premium auth-animate auth-animate-delay-2" aria-label="Reset password form">
          <div class="auth-header">
            <p class="auth-kicker">Set new password</p>
            <h2>Reset password</h2>
            <p class="auth-subtitle">Enter your new password and confirm it below.</p>
          </div>

          <% if (error) { %>
            <section class="alert alert-error" aria-live="polite">
              <p><%= error %></p>
            </section>
          <% } %>

          <% if (success) { %>
            <section class="alert alert-success" aria-live="polite">
              <p><%= success %></p>
            </section>
          <% } %>

          <% if (showForm) { %>
            <form class="auth-form" action="/reset-password/<%= token %>" method="POST" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

              <div class="form-field">
                <div class="floating-field auth-password-wrap">
                  <input
                    id="password"
                    name="password"
                    type="password"
                    placeholder=" "
                    required
                    minlength="8"
                    autocomplete="new-password"
                  />
                  <label for="password">New password</label>
                </div>
              </div>

              <div class="form-field">
                <div class="floating-field auth-password-wrap">
                  <input
                    id="confirmPassword"
                    name="confirmPassword"
                    type="password"
                    placeholder=" "
                    required
                    minlength="8"
                    autocomplete="new-password"
                  />
                  <label for="confirmPassword">Confirm password</label>
                </div>
              </div>

              <button type="submit" class="btn btn-primary auth-submit btn-block">Update password</button>
            </form>
          <% } %>

          <div class="auth-help auth-help-premium">
            <p>Need another link?</p>
            <a class="auth-back" href="/forgot-password">Request reset again</a>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
